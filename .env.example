# ─── URLS DO NEXT.JS ──────────────────────────────────────────────────────────
# CRÍTICO: Em produção no Easypanel, mude para o hostname interno do serviço Next.js.
# O nome do serviço no Easypanel é o "Service Name" que você configurou.
# Exemplo: se o projeto é "frontend" e o serviço é "landpage"
#   → NEXT_JS_BASE_URL=http://landpage:3000
# NÃO use a URL pública (https://plugandoia.cloud) — use a interna entre containers.
NEXT_JS_BASE_URL=http://localhost:3000

# Estas 3 variáveis são compostas a partir de NEXT_JS_BASE_URL automaticamente.
# Só configure individualmente se precisar de URLs diferentes.
# NEXT_JS_INGEST_URL=http://landpage:3000/api/worker/ingest
# NEXT_JS_SOURCES_URL=http://landpage:3000/api/worker/sources
# NEXT_JS_LOG_URL=http://landpage:3000/api/pipeline/log

# ─── AUTENTICAÇÃO ─────────────────────────────────────────────────────────────
WORKER_SECRET_KEY=super-secret-worker-key-123

# ─── FASTAPI DE GERAÇÃO DE VÍDEO ──────────────────────────────────────────────
# Em produção, aponte para o hostname interno do serviço Python (este mesmo container).
# Se scraper.py e video.py estão no mesmo container → localhost:80 ou localhost:8000
FASTAPI_URL=http://localhost:8000/gerar-video

# ─── PEXELS (fundos temáticos de vídeo) ───────────────────────────────────────
PEXELS_API_KEY=dLRW9uEw4c4c4AA92RDBywJX8VTM9Ft4CPiAR4buJcGvPa5FhFM64B6B

# ─── OPENAI ───────────────────────────────────────────────────────────────────
